# =============================================================================
# Bhu-Overlay -- LLM Provider Configuration Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to  .env
#      (Windows)  copy .env.example .env
#      (macOS/Linux) cp .env.example .env
#   2. Fill in the values for the provider you want to use.
#   3. Place the .env file in the  backend/  folder (next to app.py).
#   4. The .env file is listed in .gitignore -- your API keys will NOT be
#      committed to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM_PROVIDER  -- selects the active LLM backend
# Valid values : gemini | grok | local
# Default      : gemini
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini


# =============================================================================
# OPTION A -- Google Gemini  (LLM_PROVIDER=gemini)
# Get your free API key at: https://aistudio.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
# Optional -- change the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash


# =============================================================================
# OPTION B -- xAI Grok  (LLM_PROVIDER=grok)
# Get your API key at: https://console.x.ai/
# =============================================================================
# GROK_API_KEY=your_grok_api_key_here
# Optional -- change the model or endpoint
# GROK_MODEL=grok-2-latest
# GROK_API_URL=https://api.x.ai/v1/chat/completions


# =============================================================================
# OPTION C -- Local LLM via LM Studio or Ollama  (LLM_PROVIDER=local)
# Start LM Studio and enable its local server on port 1234.
# =============================================================================
# LLM_API_URL=http://localhost:1234/v1/chat/completions
# LLM_MODEL_NAME=gemma-3-4b-it
