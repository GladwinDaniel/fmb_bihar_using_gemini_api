# Python caches
__pycache__/
*.py[cod]
*$py.class

# Local JSON caches for BhuNaksha
dropdown_cache.json
extent_cache.json
local_proxy_response.json
giscode_cache.json
pniu_cache.json
plot_at_xy_cache.json

# Backend-generated cache/cookie files
backend/dropdown_cache.json
backend/extent_cache.json
backend/giscode_cache.json
backend/pniu_cache.json
backend/plot_at_xy_cache.json
backend/session_cookies.json
session_cookies.json

# WMS tile cache (generated at runtime)
static/wms_cache/
backend/static/wms_cache/

# SQLite database (Phase 2)
bhunaksha.db
backend/instance/
backend/instance/*.db

# Downloaded PDF reports (Phase 2)
static/reports/

# Python test cache
.pytest_cache/

# IDE -- ignore personal settings, but KEEP shared team config
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Python virtual environment
venv/
.venv/

instance/
*.txt

# LLM API keys -- NEVER commit real .env
# .env.example IS committed (it's just a template, no real keys)
.env
backend/.env
!.env.example

